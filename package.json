{
  "name": "skoobi-agent",
  "version": "1.2.18",
  "description": "Telegram-first personal assistant runtime with Codex subscription primary provider and Claude SDK fallback.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "skoobi": "bin/skoobi.js"
  },
  "scripts": {
    "build": "tsc && npm run build:extensions",
    "build:extensions": "for d in extensions/claudeclaw-*/; do [ -f \"$d/tsconfig.json\" ] && (cd \"$d\" && npx tsc) || true; done",
    "start": "node dist/service.js",
    "dev": "tsx src/service.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "preflight": "bash scripts/preflight.sh",
    "selftest": "bash scripts/selftest.sh",
    "recent-errors": "bash scripts/recent-errors.sh",
    "apply:full-access": "node scripts/apply-skoobi-full-access.mjs",
    "telegram-users": "node scripts/telegram-users.mjs",
    "smoke:telegram": "node scripts/telegram-delivery-smoke.mjs",
    "smoke:voice": "bash scripts/voice-smoke.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.42",
    "@anthropic-ai/sdk": "^0.91.1",
    "@azure/identity": "^4.13.1",
    "@azure/search-documents": "^12.2.0",
    "@cloudflare/workers-types": "^4.20260425.1",
    "@mistralai/mistralai": "^2.2.1",
    "@qdrant/js-client-rest": "^1.17.0",
    "@supabase/supabase-js": "^2.104.1",
    "baileys": "^7.0.0-rc13",
    "better-sqlite3": "^11.8.1",
    "cloudflare": "^5.2.0",
    "compromise": "^14.15.0",
    "cron-parser": "^5.5.0",
    "grammy": "^1.39.3",
    "groq-sdk": "^1.1.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "read-excel-file": "^9.0.9",
    "redis": "^5.12.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
